# Copier ce fichier en .env et remplir les valeurs

# URL de la base PostgreSQL (fournie automatiquement par Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Environnement
NODE_ENV=production

# Origines autorisées (ton GitHub Pages URL)
# Ex: https://tonusername.github.io
ALLOWED_ORIGINS=https://tonusername.github.io
